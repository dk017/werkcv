generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  attribution Json?
  sourceCluster String?
  sourceLocale String?
  sourcePath String?
  createdAt DateTime @default(now())
  documents CVDocument[]
  sessions  Session[]
}

model Session {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model LoginCode {
  id        String   @id @default(uuid())
  email     String
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@index([expiresAt])
}

model CVDocument {
  id           String   @id @default(uuid())
  title        String
  data         Json
  templateId   String   @default("professional")
  colorThemeId String   @default("classic-blue")
  coverLetter  String?  @db.Text
  coverLetterUpdatedAt DateTime?
  attribution  Json?
  sourceCluster String?
  sourceLocale  String?
  startSource   String?
  userId       String?
  user         User?    @relation(fields: [userId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Template {
  id      String @id @default(uuid())
  name    String
  preview String
  config  Json
}

model Order {
  id        String   @id @default(uuid())
  email     String
  cvId      String
  product   String
  amountCents Int?
  currency  String?
  addons    String[] @default([])
  attribution Json?
  sourceCluster String?
  lemonId   String?  @unique
  paidAt    DateTime?
  createdAt DateTime @default(now())
}

model AnalyticsEvent {
  id          String   @id @default(cuid())
  event       String
  cvId        String?
  orderId     String?
  path        String?
  cluster     String?
  properties  Json?
  attribution Json?
  createdAt   DateTime @default(now())

  @@index([event, createdAt])
  @@index([cvId])
  @@index([orderId])
}

model JobSource {
  id                   String          @id @default(cuid())
  slug                 String          @unique
  companyName          String
  companySlug          String
  segment              String?
  city                 String?
  countryCode          String?
  englishFit           JobEnglishFit   @default(medium)
  providerHint         String?
  provider             JobProvider
  sourceKey            String?
  apiUrl               String?         @db.Text
  careersUrl           String          @db.Text
  status               JobSourceStatus @default(research)
  priority             Int             @default(100)
  notes                String?         @db.Text
  isActive             Boolean         @default(true)
  lastFetchedAt        DateTime?
  lastSuccessfulFetchAt DateTime?
  lastError            String?         @db.Text
  jobs                 Job[]
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  @@unique([provider, sourceKey])
  @@index([companySlug])
  @@index([provider, status])
  @@index([status, priority])
}

model Job {
  id                String          @id @default(cuid())
  sourceId          String?
  source            JobSource?      @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  provider          JobProvider
  externalId        String
  companyName       String
  companySlug       String
  title             String
  titleSlug         String
  canonicalSlug     String
  routePath         String          @unique
  locationRaw       String
  city              String?
  citySlug          String?
  countryCode       String?
  remoteMode        JobRemoteMode?
  employmentType    String?
  languageHint      JobLanguageHint @default(unknown)
  dutchRequired     Boolean?
  visaHint          Boolean?
  isNlRelevant      Boolean         @default(false)
  isEnglishFriendly Boolean         @default(false)
  isWithoutDutch    Boolean         @default(false)
  status            JobRecordStatus @default(active)
  descriptionText   String          @db.Text
  excerpt           String?         @db.Text
  applyUrl          String          @db.Text
  sourceUrl         String          @db.Text
  postedAt          DateTime?
  firstSeenAt       DateTime        @default(now())
  lastSeenAt        DateTime        @default(now())
  expiresAt         DateTime?
  keywords          String[]
  clusterTags       String[]
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([provider, externalId])
  @@index([companySlug, titleSlug])
  @@index([countryCode, citySlug, status])
  @@index([isNlRelevant, isEnglishFriendly, status])
  @@index([isWithoutDutch, status])
  @@index([lastSeenAt])
}

model JobListingPage {
  id               String         @id @default(cuid())
  slug             String         @unique
  path             String         @unique
  locale           String         @default("nl")
  kind             JobListingKind
  title            String
  heroTitle        String?
  description      String         @db.Text
  metaTitle        String
  metaDesc         String
  introText        String?        @db.Text
  filters          Json
  minJobCount      Int            @default(10)
  minCompanyCount  Int            @default(5)
  primaryCtaHref   String?
  primaryCtaLabel  String?
  relatedGuideHref String?
  isActive         Boolean        @default(true)
  isIndexable      Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([locale, kind, isActive])
}

// SEO Silo Architecture - Categories for CV examples
model CVCategory {
  id          String       @id @default(cuid())
  slug        String       @unique  // URL slug: "ict-en-software", "backend-developer-nodejs"
  name        String                // Display name: "ICT & Software"
  nameDutch   String                // Dutch name for UI
  description String       @db.Text // SEO description for the page
  type        CategoryType          // pillar, subhub, or spoke

  // Hierarchy
  parentId    String?
  parent      CVCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    CVCategory[] @relation("CategoryHierarchy")

  // Content
  sampleCV    Json?                 // Pre-filled sample CV data for this niche
  heroTitle   String?               // Hero section title
  heroText    String?      @db.Text // Hero section description
  tips        String[]              // Array of tips for this CV type

  // SEO
  metaTitle   String                // <title> tag
  metaDesc    String                // meta description
  keywords    String[]              // Target keywords

  // Sibling linking (for internal links)
  siblingIds  String[]              // IDs of related categories to link to

  // Tracking
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([parentId])
  @@index([type])
}

enum CategoryType {
  pillar   // Top-level hub: /cv-voorbeeld/ict-en-software
  subhub   // Mid-level: /cv-voorbeeld/ict-en-software/developer
  spoke    // Long-tail: /cv-voorbeeld/ict-en-software/backend-developer-nodejs
}

enum JobProvider {
  greenhouse
  lever
  ashby
  workable
}

enum JobSourceStatus {
  research
  pilot
  verified
  paused
}

enum JobEnglishFit {
  high
  medium
  low
}

enum JobRemoteMode {
  remote
  hybrid
  onsite
}

enum JobLanguageHint {
  english
  dutch
  mixed
  unknown
}

enum JobRecordStatus {
  active
  expired
  hidden
}

enum JobListingKind {
  english_speaking_nl
  without_dutch
  visa_sponsorship
  english_speaking_city
  without_dutch_city
}
